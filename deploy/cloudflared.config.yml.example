# Generated by Claudio P1-#8 scaffold. Copy to ~/.cloudflared/config.yml
# AFTER running: cloudflared tunnel login && cloudflared tunnel create claudio
#
# Substitute:
#   <TUNNEL_ID>   — printed by `cloudflared tunnel create claudio`
#   <HOSTNAME>    — the domain you want, e.g. claudio.yourdomain.com
#   <CRED_PATH>   — usually ~/.cloudflared/<TUNNEL_ID>.json (auto-created by login)

tunnel: <TUNNEL_ID>
credentials-file: <CRED_PATH>

ingress:
  - hostname: <HOSTNAME>
    service: http://localhost:8080
    originRequest:
      # WebSocket on /stream — Tunnel auto-supports WS but keep these for clarity
      noTLSVerify: true
      connectTimeout: 30s
  - service: http_status:404
