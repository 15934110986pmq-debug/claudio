PORT=8080

# 代理（如需科学上网，取消注释并填写地址）
# PROXY_URL=http://192.168.1.x:7890

# Fish Audio TTS — https://fish.audio
FISH_API_KEY=
# FISH_REFERENCE_ID=   # 可选：指定音色克隆 ID

# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_KEY=
WEATHER_CITY=Beijing

# 飞书 (Lark) 日历 — https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ACCESS_TOKEN=
FEISHU_CALENDAR_ID=primary

# UPnP / DLNA 音箱控制 URL（例如 Naim Muso 等设备）
# UPNP_DEVICE_URL=http://192.168.1.100:49152/AVTransport/control

# ── LLM (P2-#11) ───────────────────────────────────
# If set, Claudio uses the Anthropic SDK directly (~1-3s per pick).
# If unset, falls back to spawning the local `claude` CLI (~7-30s).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Auth (P1-#5) ────────────────────────────────────
# Pick ONE: Resend (easiest) or SMTP. If neither set, magic links log to
# the server console — useful for local dev.
# RESEND_API_KEY=re_xxx
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# MAIL_FROM=Claudio <noreply@yourdomain.com>
# PUBLIC_URL=https://claudio.yourdomain.com

# ── WS security (P2-#14) ───────────────────────────────
# When true, /stream WebSocket requires a valid session cookie.
# Recommended for public-facing deployments; leave false for single-user / LAN.
# ENFORCE_WS_AUTH=false

# ── Logging (P2-#13) ───────────────────────────────────
# LOG_LEVEL=info       # trace | debug | info | warn | error
# SENTRY_DSN=          # optional — when set, errors also report to Sentry
