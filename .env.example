PORT=8080

# 代理（如需科学上网，取消注释并填写地址）
# PROXY_URL=http://192.168.1.x:7890

# LLM 大脑顺序（可选）— 默认 "claude,gemini"。
# 改成 "gemini,claude" 可在没装 Claude CLI 的机器上把 Gemini 设为主用。
# BRAIN_ORDER=claude,gemini

# Gemini 备用大脑 — https://aistudio.google.com/apikey
# 不配则只用 Claude CLI；建议同时配置作为 fallback。
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash   # 可选：覆盖默认模型

# Fish Audio TTS — https://fish.audio
FISH_API_KEY=
# FISH_REFERENCE_ID=   # 可选：指定音色克隆 ID

# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_KEY=
WEATHER_CITY=Beijing

# 飞书 (Lark) 日历 — https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ACCESS_TOKEN=
FEISHU_CALENDAR_ID=primary

# UPnP / DLNA 音箱控制 URL（例如 Naim Muso 等设备）
# UPNP_DEVICE_URL=http://192.168.1.100:49152/AVTransport/control
